<div class="flex items-center gap-4">
        <div class="live-ring rounded-full p-1" style="background: linear-gradient(90deg,#00f5ff22,#8b5cf622);">
          <img id="miniAvatar" src="" alt="avatar" class="w-16 h-16 rounded-full object-cover border border-white/6 shadow-sm" />
        </div>
        <div>
          <div class="text-sm text-slate-300 font-medium" id="miniName">itsrealm12c</div>
          <div class="text-xs text-slate-400" id="miniBio">—</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Right: Projects column (spans 7/12 on large) -->
<section id="projects" class="col-span-1 lg:col-span-7">
  <div class="rounded-2xl glass-bg p-6 sm:p-8 overflow-hidden">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">Recent Projects</h2>
      <div id="projectsState" class="text-sm text-slate-400">Latest 6 repos</div>
    </div>

    <div id="reposGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <!-- Repo cards or skeletons inserted by JS -->
      <!-- Initial skeletons -->
      <template id="skeletonTemplate">
        <div class="p-4 rounded-xl repo-card skeleton min-h-[120px]"></div>
      </template>
    </div>

    <div class="mt-4 flex items-center justify-center gap-3">
      <button id="showMoreBtn" class="px-4 py-2 rounded-md text-sm font-medium bg-transparent ring-1 ring-white/6 text-slate-200/90 hover:bg-white/3 transition">Show more projects</button>
    </div>
  </div>
</section>